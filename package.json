    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Laurens-R/SemanticWebAnalyser.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Laurens-R/SemanticWebAnalyser/issues"
  },
  "homepage": "https://github.com/Laurens-R/SemanticWebAnalyser#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "sass": "^1.99.0",
    "typescript": "^6.0.2",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
